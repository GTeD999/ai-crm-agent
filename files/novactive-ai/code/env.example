# ============================================================
# Novactive AI Manager — environment variables
# ============================================================

# ---------- Application ----------
APP_ENV=production  # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=https://bot.novactive.ru  # для webhook callbacks
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=  # любая случайная строка 32+ символов
TELEGRAM_WEBHOOK_PATH=/api/telegram/webhook

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-...
OPENAI_MODEL_MAIN=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_SEC=30

# ---------- Supabase ----------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=  # service_role key, не anon!
SUPABASE_DB_URL=postgresql://postgres.xxx:[email protected]:6543/postgres  # прямое подключение

# ---------- Bitrix24 ----------
BITRIX_WEBHOOK_URL=https://novactive.bitrix24.ru/rest/1/abc123def456/
BITRIX_DEFAULT_MANAGER_ID=1  # ID менеджера в Битрикс по умолчанию
BITRIX_DEAL_CATEGORY_ID=0  # ID воронки для AI-лидов
BITRIX_HIGH_URGENCY_USER_IDS=1,2  # кому слать уведомления о срочных
BITRIX_INCOMING_WEBHOOK_SECRET=  # для валидации входящих webhook от Битрикс

# ---------- Business config ----------
AGENCY_CITY=Москва
AGENCY_PHONE=+7 (495) 123-45-67
AGENCY_NAME=Новактив
AGENCY_TIMEZONE=Europe/Moscow
AGENCY_WORK_HOURS_START=09:00
AGENCY_WORK_HOURS_END=21:00
PREMIUM_BUDGET_THRESHOLD_RUB=20000000

# ---------- Bank partners (для промпта) ----------
MORTGAGE_PARTNERS=Сбер,ВТБ,Альфа-Банк,Дом.РФ,Газпромбанк

# ---------- Limits ----------
RATE_LIMIT_MESSAGES_PER_MINUTE=10
RATE_LIMIT_MESSAGES_PER_HOUR=100
MAX_CONTEXT_MESSAGES=15
SUMMARY_EVERY_N_MESSAGES=10
MAX_TOOL_ITERATIONS=5

# ---------- Followup ----------
FOLLOWUP_STEP_1_HOURS=24
FOLLOWUP_STEP_2_DAYS=3
FOLLOWUP_STEP_3_DAYS=7
